# Copy to .env.local for `vercel dev`, or set this in the Vercel dashboard.
# Get a free token at https://app.duffel.com/join -> Developers -> Access tokens.
# A test token (duffel_test_...) returns sandbox "Duffel Airways" offers;
# a live token returns real, bookable fares.
DUFFEL_TOKEN=your_duffel_token_here
